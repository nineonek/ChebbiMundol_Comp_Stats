                              "source": [
                                        "import numpy as np\n",
                                        "import pandas as pd\n",
                                        "import matplotlib.pyplot as plt\n",
                                        "import seaborn as sns\n",
                                        "from scipy import stats\n",
                                        "from itertools import combinations\n",
                                        "\n",
                                        "import statsmodels.api as sm\n",
                                        "from statsmodels.formula.api import ols\n",
                                        "from statsmodels.stats.multicomp import pairwise_tukeyhsd\n",
                                        "from itertools import combinations\n",
                                        "\n",
                                        "\n",
                                        "# get the predicted values and residuals from the trained model\n",
                                        "y_pred    = ols_model.fittedvalues\n",
                                        "residuals = ols_model.resid\n",
                                        "\n",
                                        "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
                                        "\n",
                                        "# plot 1 : residuals vs fitted values, we want points centered around 0\n",
                                        "axes[0].scatter(y_pred, residuals, alpha=0.4, color='steelblue', s=10)\n",
                                        "axes[0].axhline(0, color='red', linewidth=1)\n",
                                        "axes[0].set_title('Residuals vs Fitted')\n",
                                        "axes[0].set_xlabel('Fitted values (log)')\n",
                                        "axes[0].set_ylabel('Residuals')\n",
                                        "\n",
                                        "# plot 2 : Q-Q plot to check if residuals follow a normal distribution\n",
                                        "stats.probplot(residuals, dist='norm', plot=axes[1])\n",
                                        "axes[1].set_title('Q-Q Plot of Residuals')\n",
                                        "\n",
                                        "# plot 3 : histogram of residuals,\n",
                                        "# it shoold look like a bell curve centered on 0\n",
                                        "axes[2].hist(residuals, bins=50, edgecolor='black', color='seagreen')\n",
                                        "axes[2].set_title('Residuals Distribution')\n",
                                        "axes[2].set_xlabel('Residuals')\n",
                                        "\n",
                                        "plt.tight_layout()\n",
                                        "plt.show()\n"
                              ]
                    },
                    {
                              "cell_type": "markdown",
                              "metadata": {},
                              "source": [
                                        "### Interpretation of Residual Plots\n",
                                        "\n",
                                        "**Plot 1 - Residuals vs Fitted** : the points are mostly around 0 which means the model \n",
                                        "is not really biased. The spread looks more homogeneous now that we removed the extreme outliers.\n",
                                        "Overall the model is not really biased.\n",
                                        "\n",
                                        "**Plot 2 - Q-Q Plot** : most points follow the red line so the residuals are roughly normal. \n",
                                        "There is still some deviation at the bottom left which shows the distribution is slightly left-skewed,\n",
                                        "but it is much better than before removing the outliers.\n",
                                        "\n",
                                        "**Plot 3 - Residuals Distribution** : looks like a bell curve centered on 0 which is good. \n",
                                        "It is slightly skewed to the left but overall the normality assumption holds reasonably well.\n",
                                        "\n",
                                        "**Conclusion** : the residuals are approximately normal and centered on 0. \n",
                                        "After removing the 2 extreme outliers (GrLivArea > 4000 and SalePrice < 300k), \n",
                                        "the model improved from R² = 0.816 to R² = 0.852."
                              ]
