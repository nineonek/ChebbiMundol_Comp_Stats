  {
   "cell_type": "code",
   "execution_count": 153,
   "metadata": {},
   "outputs": [],
   "source": [
    "class FactorialDesign:\n",
    "    def __init__(self, df, target_col, f1, f2, f3):\n",
    "        self.df = df.copy()\n",
    "        self.target = target_col\n",
    "        self.f1 = f1\n",
    "        self.f2 = f2\n",
    "        self.f3 = f3\n",
    "        self.means = None\n",
    "\n",
    "    def binarize_data(self):\n",
    "        #we need to have binary factors for the test so we split into High/Low\n",
    "        def split_qual(val):\n",
    "            # OverallQual goes from 1 to 10, above 5 is considered high quality\n",
    "            if val > 5:\n",
    "                return 'High'\n",
    "            else:\n",
    "                return 'Low'\n",
    "                \n",
    "        def split_kitchen(val):\n",
    "            # Ex(Exellent) and Gd(Good) are the two best grades so we group them as High\n",
    "            #and the rest is low quality\n",
    "            if val in ['Ex', 'Gd']:\n",
    "                return 'High'\n",
    "            else:\n",
    "                return 'Low'\n",
    "                \n",
    "        self.df[self.f1] = self.df[self.f1].apply(split_qual)\n",
    "        self.df[self.f2] = self.df[self.f2].apply(split_kitchen)\n",
    "        # CentralAir is already binary (Yes/No) so we don't need to touch it\n",
    "\n",
    "    def compute_means(self):\n",
    "        # we compute the mean SalePrice_log (signe table) for 3 factors that they have been chosen \n",
    "        self.means = self.df.groupby([self.f1, self.f2, self.f3])[self.target].mean()\n",
    "        print(self.means)\n",
    "\n",
    "    def analyze_effects(self):\n",
    "        #factorial model with solo effects + double interactions + triple interaction\n",
    "        formula = f\"{self.target} ~ C({self.f1}) + C({self.f2}) + C({self.f3}) + C({self.f1}):C({self.f2}) + C({self.f1}):C({self.f3}) + C({self.f2}):C({self.f3}) + C({self.f1}):C({self.f2}):C({self.f3})\"\n",
    "        # 'ols' fits a linear regression model using the formula\n",
    "        model = ols(formula, data=self.df).fit()\n",
    "        # 'anova_lm' computes SS, F and p-value for each term in the model\n",
    "        anova = sm.stats.anova_lm(model, typ=2)# typ=2 so the order we put the variables doesnt affect the result\n",
    "        print(\"\\nFactorial Design Results :\")\n",
    "        for term in anova.index[:-1]:  # skip Residual\n",
    "            p = anova.loc[term, 'PR(>F)'] # get the p-value for this effect\n",
    "            sig = \"✅\" if p < 0.05 else \"❌\"\n",
    "            print(f\"{sig} {term}: F={anova.loc[term,'F']:.2f}, p={p:.3e}\")\n",
    "        print(\"\\nConclusion :\")\n",
    "        print(\"CentralAir has an independent effect on SalePrice (no significant interaction).\")\n",
    "        print(\"OverallQual x KitchenQual interaction is significant: kitchen quality matters more in high-quality homes.\")\n",
    "\n",
    "    def plot_interaction(self):\n",
    "        fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "        \n",
    "        # lines crossing or converging = interaction, lines parallel = no interaction\n",
    "        sns.pointplot(data=self.df, x=self.f1, y=self.target, hue=self.f2, ax=axes[0])\n",
    "        axes[0].set_title(f'{self.f1} × {self.f2} (significant)')\n",
    "        axes[0].set_xlabel(self.f1)\n",
    "        axes[0].set_ylabel('SalePrice_log')\n",
    "        \n",
    "        sns.pointplot(data=self.df, x=self.f1, y=self.target, hue=self.f3, ax=axes[1])\n",
    "        axes[1].set_title(f'{self.f1} × {self.f3} (not significant)')\n",
    "        axes[1].set_xlabel(self.f1)\n",
    "        \n",
    "        sns.pointplot(data=self.df, x=self.f2, y=self.target, hue=self.f3, ax=axes[2])\n",
    "        axes[2].set_title(f'{self.f2} × {self.f3} (not significant)')\n",
    "        axes[2].set_xlabel(self.f2)\n",
    "\n",
    "        plt.tight_layout()\n",
    "        plt.show()\n"
   ]
