                              "source": [
                                        "train[\"SalePrice_log\"] = np.log1p(train[\"SalePrice\"])\n",
                                        "\n",
                                        "SalePrice = train[\"SalePrice\"]\n",
                                        "SalePrice_log = train[\"SalePrice_log\"]\n",
                                        "\n",
                                        "#we look at the basic stats of SalePrice\n",
                                        "print(\"SalePrice Original :\")\n",
                                        "print(f\"Mean     : {SalePrice.mean():.0f} $\")\n",
                                        "print(f\"Variance : {SalePrice.var():.3f}\")\n",
                                        "print(f\"Std      : {SalePrice.std():.1f} $\")\n",
                                        "print(f\"Skewness : {SalePrice.skew():.3f}\")\n",
                                        "\n",
                                        "# Because SalePrice is very skewed, we do a log transformation to make it more normal\n",
                                        "print(\"\\nSalePrice Log :\")\n",
                                        "print(f\"Mean     : {SalePrice_log.mean():.3f}\")\n",
                                        "print(f\"Variance : {SalePrice_log.var():.3f}\")\n",
                                        "print(f\"Std      : {SalePrice_log.std():.3f}\")\n",
                                        "print(f\"Skewness : {SalePrice_log.skew():.3f}\")\n",
                                        "\n",
                                        "# we also check key features to see using a dataframe table\n",
                                        "key_features = ['GrLivArea', 'TotalBsmtSF', 'OverallQual', 'YearBuilt']\n",
                                        "print(\"\\nKey Features Statistics :\")\n",
                                        "display(train[key_features].agg(['mean', 'std', 'var', 'skew']).round(2))\n",
                                        "\n",
                                        "# Confidence Interval (95%) for SalePrice\n",
                                        "# We use the t-distribution since we don't know the true population variance\n",
                                        "print(\"\\nConfidence Interval (95%) :\")\n",
                                        "n = len(train)\n",
                                        "#stats.t.interval return directly the upper and the lower bound respecting all parameters\n",
                                        "#it's better than writing it manualluy with the classic maths formula\n",
                                        "#CI_original :\n",
                                        "CI_lower_log, CI_upper_log = stats.t.interval(0.95, df=n-1, loc=SalePrice_log.mean(), scale=stats.sem(SalePrice_log))\n",
                                        "print(f\"CI_log   : [{CI_lower_log:.4f} ; {CI_upper_log:.4f}]\")\n",
                                        "#CI_log :\n",
                                        "CI_lower_original, CI_upper_original = stats.t.interval(0.95, df=n-1, loc=SalePrice.mean(), scale=stats.sem(SalePrice))\n",
                                        "print(f\"CI_in_$  : [{CI_lower_original:.0f}$ ; {CI_upper_original:.0f}$]\")\n",
                                        "\n",
                                        "# Hypothesis test: is the mean SalePrice significantly different from $180,000?\n",
                                        "mu_0 = np.log1p(SalePrice.mean())\n",
                                        "#stat.ttest_1samp return a tuple with the t-stat and the p-value\n",
                                        "#it's better than writing it manualluy with the classic maths formula\n",
                                        "t_stat, p_val = stats.ttest_1samp(SalePrice_log, mu_0)\n",
                                        "print(f\"\\nHypothesis test: Mean SalePrice vs $180,000\")\n",
                                        "print(f\"H0: μ = $180,000 \\n      vs \\nH1: μ ≠ $180,000\")\n",
                                        "print(f\"t-statistic: {t_stat:.3f}, p-value: {p_val:.3f}\")\n",
                                        "if p_val < 0.05:\n",
                                        "    print(\"Conclusion: we reject H0 - Mean is significantly different from $180,000\")\n",
                                        "else:\n",
                                        "    print(\"Conclusion: we fail to reject H0 - Mean is not significantly different from $180,000\")\n",
                                        "\n",
                                        "# We test normality with Shapiro-Wilk to check if the log transformation worked well\n",
                                        "shapiro_stat, shapiro_p = stats.shapiro(SalePrice_log)\n",
                                        "print(f\"\\nShapiro-Wilk normality test for SalePrice_log:\")\n",
                                        "print(f\"Statistic: {shapiro_stat:.3f}, p-value: {shapiro_p:.3f}\")\n",
                                        "print(f\"Note: With large sample size (n={n}), Shapiro-Wilk is very strict and becomes extremely sensitive \"\n",
                                        "    \"\\nand detects small deviations from the norm that are statistically significant but practically negligible.\")\n",
                                        "print(f\"Statistic = {shapiro_stat:.3f} (close to 1.0) indicates approximately normal distribution.\")\n",
                                        "print(f\"Conclusion: The distribution is approximately normal and suitable for t-tests and ANOVA.\")\n",
                                        "\n",
                                        "# Plots to visualize the distributions and check normality\n",
                                        "fig, axes = plt.subplots(1, 3, figsize=(18, 4))\n",
