                                        "# 2. Calculate metrics (Log Scale)\n",
                                        "train_rmse = np.sqrt(mean_squared_error(y_train, y_train_pred))\n",
                                        "train_r2 = r2_score(y_train, y_train_pred)\n",
                                        "\n",
                                        "print(f\"TRAINING SET METRICS\")\n",
                                        "print(f\"RMSE (Log Scale): {train_rmse:.6f}\")\n",
                                        "print(f\"R² Score:         {train_r2:.6f}\")\n",
                                        "print(f\"\\nInterpretation:\")\n",
                                        "print(f\"   RMSE = {train_rmse:.6f}: Average prediction error (log scale)\")\n",
                                        "print(f\"   R² = {train_r2:.6f}: Model explains {train_r2*100:.2f}% of variance\")\n",
                                        "\n",
                                        "# 3. Convert back to original price scale\n",
                                        "y_train_pred_original = np.expm1(y_train_pred)\n",
                                        "y_train_original = np.expm1(y_train)\n",
                                        "rmse_original = np.sqrt(mean_squared_error(y_train_original, y_train_pred_original))\n",
                                        "\n",
                                        "print(f\"\\nOriginal Price Scale:\")\n",
                                        "print(f\"   RMSE = ${rmse_original:,.0f}\")\n",
                                        "print(f\"   Mean actual price: ${y_train_original.mean():,.0f}\")\n",
                                        "print(f\"   Error as % of mean: {(rmse_original / y_train_original.mean())*100:.2f}%\")\n",
