   "source": [
    "---\n",
    "## Part 2: ANOVA — Finding Significant Features\n",
    "\n",
    "Use ANOVA to determine which of the following **10 features** have a statistically significant effect on the transformed SalePrice. \n",
    "\n",
    "**Given features (10):**\n",
    "\n",
    "| # | Feature | Levels | Description |\n",
    "|---|---|---|---|\n",
    "| 1 | `OverallQual` | 1–10 | Overall material and finish quality |\n",
    "| 2 | `ExterQual` | Po, Fa, TA, Gd, Ex | Exterior material quality |\n",
    "| 3 | `BsmtQual` | None, Po, Fa, TA, Gd, Ex | Basement height quality |\n",
    "| 4 | `KitchenQual` | Po, Fa, TA, Gd, Ex | Kitchen quality |\n",
    "| 5 | `FireplaceQu` | None, Po, Fa, TA, Gd, Ex | Fireplace quality |\n",
    "| 6 | `CentralAir` | N, Y | Central air conditioning |\n",
    "| 7 | `LotShape` | IR3, IR2, IR1, Reg | General shape of property |\n",
    "| 8 | `LandSlope` | Sev, Mod, Gtl | Slope of property |\n",
    "| 9 | `MoSold` | 1–12 | Month sold |\n",
    "| 10 | `YrSold` | 2006–2010 | Year sold |\n",
    "\n",
    "**Tasks:**\n",
    "1. Extract these features into a dataframe and run **one-way ANOVA** on each\n",
    "2. Identify which features are significant (p < 0.05)\n",
    "3. Run a **two-way ANOVA** to test for interaction effects between pairs of significant features\n",
    "4. Use **Tukey HSD** post-hoc tests where appropriate\n",
    "5. Summarize: which features and interactions are significant?"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 149,
   "metadata": {},
   "outputs": [],
   "source": [
    "from warnings import filterwarnings\n",
    "filterwarnings('ignore')\n",
    "\n",
    "class ANOVAAnalyzer:\n",
    "    def __init__(self, df, target_col, features):\n",
    "        self.df = df\n",
    "        self.target_col = target_col\n",
    "        self.features = features\n",
    "        \n",
    "        self.one_way_results = {}    \n",
    "        self.significant_features = [] \n",
    "        self.two_way_results = {}\n",
    "        self.pvalue_matrix = None  # Store all p-values for heatmap\n",
    "        self.tukey_results = {}       \n",
    " \n",
    "    def run_one_way_anova(self):\n",
    "        \"\"\"We are testing which features individually impact the SalePrice\"\"\"\n",
    "        for feature in self.features: #we iterate through all features\n",
    "            data_groups = [] #list to store the SalePrice values for each group of the feature\n",
    "            grouped_data = self.df.groupby(feature) #grouping data frame by feature\n",
    "            \n",
    "            \"\"\" For each feature, we first select the target (SalePrice) from the grouped data frame.\n",
    "            To add the different values per feature group to the series list\"\"\"\n",
    "            for name, group_df in grouped_data:\n",
    "                series = group_df[self.target_col].dropna() \n",
    "                data_groups.append(series)\n",
    " \n",
    "            #'*' unpacks the list so f_oneway can get each array as a separate argument\n",
    "            f_stat, p_val = stats.f_oneway(*data_groups)\n",
    "            self.one_way_results[feature] = p_val #dictionary to store the p-values for each feature\n",
    "            \n",
    " \n",
    "            if p_val < 0.05:\n",
    "                self.significant_features.append(feature)\n",
    "            \n",
    "    def run_two_way_anova(self):\n",
    "        \"\"\"\n",
    "        We are now testing for interactions between the different features. Does 'CentralAir' matter more when 'OverallQual' is high?\n",
    "        For a Two-Way ANOVA, the \"manual\" grouping will get a lot trickier, so we will fit an OLS model using statsmodels, and run \n",
    "        stats.anova_lm() on it\n",
    " \n",
    "        \n",
    "        We need a smart filter here. If a specific combination (like Quality 2 + Excellent Kitchen) \n",
    "        only has 1 or 2 houses, the model will overreact to outliers and give us \"fake\" interactions.\n",
    "        \"\"\"\n",
    "        #combinations returns pairs as tuples\n",
    "        combis = list(combinations(self.significant_features, 2))\n",
    "        n_features = len(self.significant_features)\n",
    "        \n",
    "        # Initialize matrix to store all p-values\n",
    "        self.pvalue_matrix = np.full((n_features, n_features), np.nan)\n",
    "        \n",
    "        skipped_count = 0\n",
    "        \n",
    "        for feature1, feature2 in combis: \n",
    "            #Define Formula\n",
    "            formula = f\"{self.target_col} ~ C({feature1}) + C({feature2}) + C({feature1}):C({feature2})\" \n",
    " \n",
    " \n",
    "            #beginning of the smart filter\n",
    "            cross_tab = pd.crosstab(self.df[feature1], self.df[feature2])\n",
    "            \n",
    "            sparse_cells = (cross_tab < 5).sum().sum() #counting how many feature combinations have less than 5 houses\n",
    "            total_cells = cross_tab.size\n",
    "            \n",
    "            # if more than 75% of our combinations are basically empty, it's too noisy to trust and we exclude them from the analysis\n",
    "            if (sparse_cells / total_cells) > 0.75:\n",
    "                skipped_count += 1\n",
    "                #print(f\"Skipping {feature1} * {feature2}: Too much missing/sparse data.\")\n",
    "                continue\n",
    "                \n",
    " \n",
    "            #fit the OLS\n",
    "            model = ols(formula, data=self.df).fit()\n",
    "            \n",
    "            anova = sm.stats.anova_lm(model, typ=2) #Using typ=2 ensures the order of feature1 and feature2 doesn't bias the result\n",
    " \n",
    "            interaction_term = f\"C({feature1}):C({feature2})\" #--> extracting the p-value\n",
    "            p_interaction = anova.loc[interaction_term, 'PR(>F)']\n",
    "            \n",
    "            # Store in both symmetric positions\n",
    "            idx1 = self.significant_features.index(feature1)\n",
    "            idx2 = self.significant_features.index(feature2)\n",
    "            self.pvalue_matrix[idx1, idx2] = p_interaction\n",
    "            self.pvalue_matrix[idx2, idx1] = p_interaction\n",
    "            \n",
    "            # Also store in two_way_results dictionary if significant\n",
    "            if p_interaction < 0.05:\n",
    "                self.two_way_results[f\"{feature1} * {feature2}\"] = p_interaction\n",
    "        \n",
    "        if skipped_count > 0:\n",
    "            print(f\"\\nSkipped {skipped_count} interaction(s) due to sparsity\")\n",
    " \n",
    "    \n",
    " \n",
    "    def summarize_results(self):\n",
    "        print(\"\\n--- ANOVA Summary ---\")\n",
    "        \n",
    "        print(f\"\\nSignificant features ({len(self.significant_features)} total):\")\n",
    "        for f in self.significant_features:\n",
    "            print(f\"  * {f} (p = {self.one_way_results[f]})\")\n",
    "            \n",
    "        print(\"\\nInteractions (p < 0.05):\")\n",
    "        if not self.two_way_results:\n",
    "            print(\"  none\")\n",
    "        else:\n",
    "            for k, v in self.two_way_results.items():\n",
    "                print(f\"  * {k} (p = {v})\")"
   ]
  },
