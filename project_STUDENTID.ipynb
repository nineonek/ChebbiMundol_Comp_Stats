    "import statsmodels.api as sm\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from sklearn.impute import SimpleImputer\n",
    "\n",
    "train = pd.read_csv('train.csv')\n",
    "# dropping outliers \n",
    "train = train.drop(train[(train['GrLivArea'] > 4000) & (train['SalePrice'] < 300000)].index)\n",
    "train[\"SalePrice_log\"] = np.log1p(train[\"SalePrice\"])\n",
    "\n",
    "# Same log-transform \n",
    "train['GrLivArea'] = np.log1p(train['GrLivArea'])\n",
    "train['TotalBsmtSF'] = np.log1p(train['TotalBsmtSF'].fillna(0))\n",
    "\n",
    "# we use the 7 features that were significant in Part 2, + 2 numerical features\n",
    "ordinal_features = ['OverallQual', 'ExterQual', 'BsmtQual', 'KitchenQual',\n",
    "                    'FireplaceQu', 'CentralAir', 'LotShape']\n",
    "numerical_features = ['GrLivArea', 'TotalBsmtSF']\n",
    "\n",
    "# OLS only works with numbers so we replace the text levels with integers\n",
    "# In order : for ex; Po=1 (worst) -> Ex=5 (best)\n",
    "ordinal_maps = {\n",
    "    'ExterQual':   {'Po': 1, 'Fa': 2, 'TA': 3, 'Gd': 4, 'Ex': 5},\n",
    "    'BsmtQual':    {'NA': 0, 'Po': 1, 'Fa': 2, 'TA': 3, 'Gd': 4, 'Ex': 5},\n",
    "    'KitchenQual': {'Po': 1, 'Fa': 2, 'TA': 3, 'Gd': 4, 'Ex': 5},\n",
    "    'FireplaceQu': {'NA': 0, 'Po': 1, 'Fa': 2, 'TA': 3, 'Gd': 4, 'Ex': 5},\n",
    "    'CentralAir':  {'N': 0, 'Y': 1},\n",
    "    'LotShape':    {'IR3': 1, 'IR2': 2, 'IR1': 3, 'Reg': 4},\n",
    "}\n",
    "\n",
    "# we make a copy of train so we dont replace the original data,\n",
    "# we will modify it to replace text by numbers\n",
    "df_regression = train.copy()\n",
    "\n",
    "# NaN here means no basement or no fireplace, so we treat it as level 0\n",
    "for col in ['BsmtQual', 'FireplaceQu']:\n",
    "    df_regression[col] = df_regression[col].fillna('NA')\n",
    "\n",
    "# apply the mapping on each column\n",
    "for col, mapping in ordinal_maps.items():\n",
    "    df_regression[col] = df_regression[col].map(mapping)\n",
    "\n",
    "all_features = ordinal_features + numerical_features\n",
    "#we keep the 9 features that we need + the SalePrice \n",
    "# and we drop the rows(houses) in our 10 Features that have missing value using '.dropna()'\n",
    "df_regression = df_regression[all_features + ['SalePrice_log']]\n",
    "\n",
    "imputer = SimpleImputer(strategy='median')\n",
    "df_regression[all_features] = imputer.fit_transform(df_regression[all_features])\n",
    "\n",
    "# X is what we give to the model and y is what we want to predict\n",
    "X = df_regression[all_features]\n",
    "y = df_regression['SalePrice_log']\n",
    "\n",
    "print(f\"Dataset : {X.shape[0]} lignes, {X.shape[1]} features\")\n",
    "display(X.head(3))\n",
    "\n",
    "print(f\"df shape: {df_regression.shape}\")\n",
    "print(f\"X shape: {X.shape}\")\n",
    "print(f\"NaN in X: {X.isnull().sum().sum()}\")\n",
    "\n",
    "# we add a constant column for the intercept β0\n",
    "X_const = sm.add_constant(X)\n",
    "ols_model = sm.OLS(y, X_const).fit() # fit the OLS model\n",
    "print(ols_model.summary()) #display the full results\n",
    "\n",
    "# the coefficients are in log scale,\n",
    "# so we use e^coef - 1 to get the % effect on real price\n",
    "print(\"Interpretation of coefficients (original scale):\")\n",
    "for feature, coef in ols_model.params[1:].items():\n",
    "    percentage = (np.exp(coef) - 1) * 100\n",
    "    print(f\"  --> {feature:15} : {percentage:+.2f}%\")\n",
    "\n"
   ]
  },
