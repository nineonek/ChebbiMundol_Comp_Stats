                                                            "  * KitchenQual * FireplaceQu (p = 1.7654146979888007e-90)\n",
                                                            "  * KitchenQual * LotShape (p = 0.0007421622758960538)\n",
                                                            "  * FireplaceQu * CentralAir (p = 2.7052138768589744e-213)\n"
                                                  ]
                                        }
                              ],
                              "source": [
                                        "target = 'SalePrice_log' \n",
                                        "test_features = [\n",
                                        "    'OverallQual', 'ExterQual', 'BsmtQual', 'KitchenQual', \n",
                                        "    'FireplaceQu', 'CentralAir', 'LotShape', 'LandSlope', \n",
                                        "    'MoSold', 'YrSold'\n",
                                        "]\n",
                                        "\n",
                                        "\n",
                                        "# 1. Instantiate the framework\n",
                                        "analyzer = ANOVAAnalyzer(df=train, target_col=target, features=test_features)\n",
                                        "\n",
                                        "analyzer.run_one_way_anova()\n",
                                        "analyzer.run_two_way_anova()\n",
                                        "\n",
                                        "analyzer.summarize_results()"
                              ]
                    },
                    {
                              "cell_type": "code",
                              "execution_count": 49,
                              "metadata": {},
                              "outputs": [],
                              "source": [
                                        "import math\n",
                                        "\n",
                                        "def plot_interaction_grids(df, significant_features, max_cols=3):\n",
                                        "    \n",
                                        "    #Generate all unique pairs of significant features\n",
                                        "    feature_pairs = list(combinations(significant_features, 2))\n",
                                        "    n_pairs = len(feature_pairs)\n",
                                        "\n",
                                        "\n",
                                        "    n_cols = min(max_cols, n_pairs)\n",
                                        "    n_rows = math.ceil(n_pairs / n_cols)\n",
                                        "    fig, axes = plt.subplots(n_rows, n_cols, figsize=(5 * n_cols, 5 * n_rows))\n",
                                        "    fig.subplots_adjust(hspace=0.5, wspace=0.4)\n",
                                        "    \n",
                                        "    # Flatten axes array for easy iteration, handling cases with 1 row or 1 plot\n",
                                        "    if n_pairs == 1:\n",
                                        "        axes = [axes]\n",
                                        "    elif n_rows > 1:\n",
                                        "        axes = axes.flatten()\n",
                                        "        \n",
                                        "    for i, (feat1, feat2) in enumerate(feature_pairs):\n",
                                        "        ax = axes[i]\n",
                                        "        \n",
                                        "        # Create a cross-tabulation (counts the number of houses for each combination)\n",
                                        "        crosstab = pd.crosstab(df[feat1], df[feat2])\n",
                                        "        \n",
                                        "        # Plot the heatmap\n",
                                        "        # cmap='YlOrRd' gives a nice yellow (low count) to red (high count) color scheme\n",
                                        "        # annot=True puts the actual numbers inside the squares\n",
                                        "        sns.heatmap(crosstab, ax=ax, cmap=\"YlOrRd\", annot=True, fmt='d', \n",
                                        "                    cbar=False, linewidths=.5, linecolor='lightgrey')\n",
                                        "        \n",
                                        "        # Styling the subplot\n",
                                        "        ax.set_title(f\"{feat1} vs {feat2}\", fontsize=12, fontweight='bold', pad=10)\n",
                                        "        ax.set_xlabel(feat2, fontsize=10)\n",
                                        "        ax.set_ylabel(feat1, fontsize=10)\n",
                                        "        ax.tick_params(axis='both', which='major', labelsize=8)\n",
                                        "\n",
                                        "    # 5. Hide any unused subplots (if n_pairs doesn't perfectly fill the grid)\n",
                                        "    for j in range(i + 1, len(axes)):\n",
                                        "        fig.delaxes(axes[j])\n",
                                        "        \n",
                                        "    # Add a main title\n",
                                        "    plt.suptitle(\"House Count by Feature Interaction Combinations\", \n",
                                        "                 fontsize=16, fontweight='bold', y=1.02)\n",
                                        "    \n",
                                        "    plt.tight_layout()\n",
                                        "    plt.show()\n",
                                        "\n",
                                        "\n",
                                        "\n",
                                        "def plot_interaction_pvalues(analyzer):\n",
                                        "    \"\"\"\n",
                                        "    Creates a heatmap showing p-values for all two-way interaction effects.\n",
                                        "    Uses pre-computed p-values from ANOVA analyzer.\n",
                                        "    Green = significant interaction (p < 0.05), Red = not significant (p >= 0.05)\n",
                                        "    \"\"\"\n",
                                        "    pvalue_matrix = analyzer.pvalue_matrix\n",
                                        "    significant_features = analyzer.significant_features\n",
                                        "    \n",
                                        "    # Create heatmap\n",
                                        "    fig, ax = plt.subplots(figsize=(10, 8))\n",
                                        "    \n",
                                        "    # Use mask for diagonal\n",
                                        "    mask = np.isnan(pvalue_matrix)\n",
                                        "    np.fill_diagonal(mask, True)  # Mask diagonal\n",
                                        "    \n",
                                        "    # Custom colormap: green for significant (p < 0.05), red for not significant\n",
                                        "    sns.heatmap(pvalue_matrix, annot=True, fmt='.3f', cmap='RdYlGn_r', \n",
                                        "                center=0.05, vmin=0, vmax=0.15, mask=mask,\n",
                                        "                square=True, ax=ax, cbar_kws={'label': 'p-value'},\n",
                                        "                xticklabels=significant_features, yticklabels=significant_features)\n",
                                        "    \n",
                                        "    ax.set_title('Two-Way ANOVA Interaction p-Values\\n(Green = significant p<0.05, Red = not significant)', \n",
                                        "                 fontsize=14, fontweight='bold', pad=15)\n",
                                        "    plt.tight_layout()\n",
                                        "    plt.show()"
                              ]
                    },
