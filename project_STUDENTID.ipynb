    "import math\n",
    "\n",
    "def plot_interaction_grids(df, significant_features, max_cols=3):\n",
    "    \n",
    "    #Generate all unique pairs of significant features\n",
    "    feature_pairs = list(combinations(significant_features, 2))\n",
    "    n_pairs = len(feature_pairs)\n",
    "\n",
    "\n",
    "    n_cols = min(max_cols, n_pairs)\n",
    "    n_rows = math.ceil(n_pairs / n_cols)\n",
    "    fig, axes = plt.subplots(n_rows, n_cols, figsize=(5 * n_cols, 5 * n_rows))\n",
    "    fig.subplots_adjust(hspace=0.5, wspace=0.4)\n",
    "    \n",
    "    # Flatten axes array for easy iteration, handling cases with 1 row or 1 plot\n",
    "    if n_pairs == 1:\n",
    "        axes = [axes]\n",
    "    elif n_rows > 1:\n",
    "        axes = axes.flatten()\n",
    "        \n",
    "    for i, (feat1, feat2) in enumerate(feature_pairs):\n",
    "        ax = axes[i]\n",
    "        \n",
    "        # Create a cross-tabulation (counts the number of houses for each combination)\n",
    "        crosstab = pd.crosstab(df[feat1], df[feat2])\n",
    "        \n",
    "        # Plot the heatmap\n",
    "        # cmap='YlOrRd' gives a nice yellow (low count) to red (high count) color scheme\n",
    "        # annot=True puts the actual numbers inside the squares\n",
    "        sns.heatmap(crosstab, ax=ax, cmap=\"YlOrRd\", annot=True, fmt='d', \n",
    "                    cbar=False, linewidths=.5, linecolor='lightgrey')\n",
    "        \n",
    "        # Styling the subplot\n",
    "        ax.set_title(f\"{feat1} vs {feat2}\", fontsize=12, fontweight='bold', pad=10)\n",
    "        ax.set_xlabel(feat2, fontsize=10)\n",
    "        ax.set_ylabel(feat1, fontsize=10)\n",
    "        ax.tick_params(axis='both', which='major', labelsize=8)\n",
    "\n",
    "    # 5. Hide any unused subplots (if n_pairs doesn't perfectly fill the grid)\n",
    "    for j in range(i + 1, len(axes)):\n",
    "        fig.delaxes(axes[j])\n",
    "        \n",
    "    # Add a main title\n",
    "    plt.suptitle(\"House Count by Feature Interaction Combinations\", \n",
    "                 fontsize=16, fontweight='bold', y=1.02)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "\n",
    "\n",
    "def plot_interaction_pvalues(analyzer):\n",
